# Copy your .env here and fill in real values. DO NOT commit actual keys.
KALSHI_KEY=your_kalshi_key_here
KALSHI_SECRET=your_kalshi_secret_here
KALSHI_TRADING_KEY=your_kalshi_trading_key_here
KALSHI_TRADING_SECRET_FILE=/opt/slimy/pm_updown_bot_bundle/keys/kalshi-trading.key

XAI_API_KEY=your_xai_api_key_here
GLM_API_KEY=your_glm_api_key_here

# AI cost control — add to .env and adjust as needed:
AI_MAX_PRIORS_PER_RUN=50
AI_PRIMARY_PROVIDER=glm
AI_PREMIUM_PROVIDER=grok_420
AI_PREMIUM_MAX=10
